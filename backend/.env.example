#
# Required environment variables (no real credentials)
#

# Server port for the Express API
PORT=5000

# App environment
NODE_ENV=development

# PostgreSQL connection string (required).
# Placeholder format (Railway uses this style):
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Frontend origin for CORS
CORS_ORIGIN=http://localhost:5173

# Secret key used for signing/tokens (required; replace with your own)
APP_SECRET=your_change_me_secret

# Optional: set to "require" to enable SSL for Postgres
# Railway Postgres commonly requires SSL:
PGSSLMODE=require

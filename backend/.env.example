#
# Required environment variables (no real credentials)
#

# Server port for the Express API
PORT=5000

# App environment
NODE_ENV=development

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional frontend origin for CORS in local development
CORS_ORIGIN=http://localhost:5173

# Optional secret (if your app uses signing/tokens)
APP_SECRET=your_change_me_secret

# Optional: set to "require" to enable SSL for Postgres
# Railway Postgres commonly requires SSL:
PGSSLMODE=require
